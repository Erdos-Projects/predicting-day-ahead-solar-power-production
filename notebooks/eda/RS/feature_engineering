    def calc_energy_lrs(self, data:pd.DataFrame)->int:
        """approximates energy produced via a left Riemann sum

        Args:
            data (pd.DataFrame): dataframe containing the columns 'time' (of type datetime) and 'power' (of type float)

        Returns:
            int: total energy produced over the entire period in kWh
        """
        df=pd.DataFrame()
        df['time']=pd.to_datetime(data['time'])
        df['power']=data['power']
        df['time_gap_hours'] = (df['time'].shift(-1)-df['time']).dt.total_seconds()/3600
        if len(df.loc[df['time_gap_hours']>1])>0:
            long_gaps = df.loc[df['time_gap_hours']>1]
            if len(long_gaps.loc[long_gaps['power']>0])>0:
                print("There is a long gap in non-zero data. The calculated energy is likely incorrect.")
        df=df.dropna()
        df['energy']=df['power']*df['time_gap_hours']
        return df['energy'].sum()
    
