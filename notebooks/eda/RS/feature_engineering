    def n_consecutive_days(self, data: pd.Series, n: int)-> pd.Series:
        """given a series, list, or dataframe of days, says where you have a list of n consecutive days
        Note that if you want 14 days train/1 day test, will need n=15
        Moreover, if need to calculate lags/incorporate past days' info as exogenous variables, will need even larger n

        Args:
            data (series): must be a list of DAYS
            n (int): number of consecutive entries we're looking for

        Returns:
            pd.Series: list of days which END an n-day streak
        """
        df = pd.DataFrame()
        df['day'] = pd.to_datetime(data)
        df = df.sort_values('day')
        df['days_between'] = (df['day']-df['day'].shift(1)).dt.days
        df['days_between_is_1'] = (df['days_between']==1).astype(int)
        df['streak_n'] = (df['days_between_is_1'] == 1).rolling(n).sum().eq(n)
        
        return df.loc[df['streak_n'],'day']
    
    def has_one_year_ago(self, data: pd.Series) -> pd.Series:
        """given a series of dates, returns whether the day one year earlier is in the series.
        NOTE: one year before Feb 29 will be automatically set to Feb 28

        Args:
            data (pd.Series): dates mm/dd/yyyy

        Returns:
            pd.Series: subset of input dates
        """
        df = pd.DataFrame()
        df['day'] = pd.to_datetime(data)
        #will look up this day but last year in the collection of days
        #turn into a set, then look up in the set
        day_set = set(df['day'])
        df['has_last_year'] = df['day'].apply(lambda x: (x - pd.DateOffset(years=1)) in day_set)

        return df.loc[df['has_last_year'],'day']